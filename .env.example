# Supabase — get these from `npx supabase start` (local) or your Supabase project settings (production)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AES-256-GCM key for encrypting parent API keys at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_SECRET=
